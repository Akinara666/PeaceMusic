# Discord
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
CHATBOT_CHANNEL_ID=YOUR_CHATBOT_CHANNEL_ID
DISCORD_STATUS_MESSAGE=LISTENING_STATUS_TEXT

# Google Gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Optional SOCKS5 proxy for Gemini API traffic, e.g. socks5://127.0.0.1:40000
GEMINI_SOCKS_PROXY=

# Paths
MUSIC_DIRECTORY=music_files
CONTEXT_FILE=chat_context.json
BOT_PROMPT_FILE=utils/default_prompt.txt

# yt-dlp cookies (optional)
YTDL_USE_COOKIES=false
YTDL_COOKIE_FILE=data/cookies.txt

# AI rate limiting (per-user). Set MAX_REQUESTS to 0 to disable.
AI_RATE_LIMIT_MAX_REQUESTS=20
AI_RATE_LIMIT_WINDOW_SECONDS=60
