# Logging (INFO by default; set DEBUG to see yt-dlp timing diagnostics)
# LOG_LEVEL=INFO

# Discord
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
CHATBOT_CHANNEL_ID=YOUR_CHATBOT_CHANNEL_ID
DISCORD_STATUS_MESSAGE=LISTENING_STATUS_TEXT

# Google Gemini API
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GEMINI_RESPONSE_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_SUMMARY_MODEL=gemini-3.1-flash-lite-preview
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
# GEMINI_EMBEDDING_DIMENSIONS=768
# GEMINI_THINKING_BUDGET=8192
# GEMINI_TEMPERATURE=1.0
# GEMINI_TOP_P=0.95
# GEMINI_REQUEST_TIMEOUT_MS=24000
# GEMINI_SOCKS_PROXY=socks5://127.0.0.1:40000

# Paths & Settings
MUSIC_DIRECTORY=music_files
BOT_PROMPT_FILE=utils/default_prompt.txt
# CHAT_MEMORY_DB=chat_memory.sqlite3

# yt-dlp cookies (optional)
YTDL_USE_COOKIES=false
YTDL_COOKIE_FILE=data/cookies.txt
# Persistent yt-dlp player/signature cache (speeds up repeated YouTube extracts).
# Defaults under data/ so it lives in the mounted Docker volume.
# YTDL_CACHE_DIR=data/ytdl_cache

# Music Queue
# MUSIC_QUEUE_MAX_SIZE=50

# AI rate limiting (per-user). Set MAX_REQUESTS to 0 to disable.
AI_RATE_LIMIT_MAX_REQUESTS=20
AI_RATE_LIMIT_WINDOW_SECONDS=60

# Memory & Context Settings (defaults shown)
# MEMORY_RECENT_MESSAGES=12
# MEMORY_SEMANTIC_RESULTS=6
# MEMORY_SEMANTIC_MIN_SCORE=0.35
# MEMORY_SUMMARY_TRIGGER=30
# MEMORY_SUMMARY_WINDOW=40
# MEMORY_SEMANTIC_HALF_LIFE_DAYS=30
# MEMORY_SEMANTIC_CANDIDATES=1000
# MEMORY_RAW_RETENTION_DAYS=90
